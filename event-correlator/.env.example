# SAM control-plane broker
NAMESPACE="SAM/"
SOLACE_BROKER_URL="ws://localhost:8008"
SOLACE_BROKER_VPN="default"
SOLACE_BROKER_USERNAME="default"
SOLACE_BROKER_PASSWORD="default"

# Data-plane broker (may be the same as control-plane)
DATA_PLANE_BROKER_URL="ws://localhost:8008"
DATA_PLANE_BROKER_VPN="default"
DATA_PLANE_BROKER_USERNAME="default"
DATA_PLANE_BROKER_PASSWORD="default"

# Gateway identity
CORRELATOR_GATEWAY_ID="event-correlator-01"

# State store (for production)
REDIS_URL="redis://localhost:6379"

# Target agent
TARGET_AGENT_NAME="MyReconciliationAgent"
